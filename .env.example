# =============================================================================
# Painel do Síndico — Variáveis de Ambiente (EXEMPLO)
# -----------------------------------------------------------------------------
# Copie este arquivo para `.env` e preencha com os valores reais.
# O `.env` NÃO é versionado (ver .gitignore).
# Toda leitura de env deve passar por `src/settings` (config tipada/validada),
# nunca ler `process.env` espalhado pelo código.
# =============================================================================

# -----------------------------------------------------------------------------
# App / Painel
# -----------------------------------------------------------------------------
APP_ENV=development          # development | production
APP_URL=http://localhost:3000
APP_PORT=3000

# -----------------------------------------------------------------------------
# Banco de Dados (PostgreSQL)
#   LOCAL:  postgresql://postgres:senha@127.0.0.1:5432/evolution-api?schema=public
#   DOCKER: trocar host/porta pelo serviço do compose (ex.: @postgres:5432)
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Redis (cache / filas)
#   LOCAL c/ TLS (Upstash): rediss://default:TOKEN@host.upstash.io:6379
#   DOCKER: redis://redis:6379
# -----------------------------------------------------------------------------
REDIS_URL=

# -----------------------------------------------------------------------------
# Evolution API (WhatsApp)
# O painel se conecta a UMA instância:
#   - LOCAL: clone em ./evolution-api (tem o .env próprio dele)
#   - REMOTA: instância já hospedada
# Basta apontar EVOLUTION_API_URL para o alvo correto.
# -----------------------------------------------------------------------------
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=sindico

# -----------------------------------------------------------------------------
# n8n (orquestração de fluxos / webhooks)
# -----------------------------------------------------------------------------
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=
N8N_API_KEY=

# -----------------------------------------------------------------------------
# IA (extração de chamado: bloco, apto, problema, urgência)
# -----------------------------------------------------------------------------
AI_PROVIDER=gemini           # gemini | openai
GEMINI_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Login com Google (OAuth 2.0 / OpenID Connect)
# Credenciais geradas no Google Cloud Console (APIs & Services > Credentials >
# OAuth client ID > "Web application").
#   Authorized redirect URI deve bater com GOOGLE_REDIRECT_URI abaixo.
#   Se GOOGLE_REDIRECT_URI ficar vazio, o padrão é `${APP_URL}/api/auth/google/callback`.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
